# Copia este archivo a .env.local y llena los valores.
# Las variables VITE_* terminan en el bundle publico: aqui NUNCA va un secreto.

# URL de la Lambda Function URL que hace de fallback del estafador.
# Si se deja vacia, el juego usa el LLM on-device o el guion local.
VITE_LLM_ENDPOINT=

# --- Variables de despliegue (van en .env.deploy, no en .env.local) ---
# BUCKET=ponte-trucha-web
# DISTRIBUTION_ID=E123456ABCDEF
# DOMINIO=d1234abcd.cloudfront.net

# --- Variables de la Lambda (se configuran en AWS, NO en este repo) ---
# MISTRAL_API_KEY=
# ORIGEN_PERMITIDO=https://d1234abcd.cloudfront.net
# MISTRAL_MODEL=mistral-small-latest

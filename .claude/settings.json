{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run build)",
      "Bash(npm run validar:escenarios)",
      "Bash(npm run dev)",
      "Bash(node scripts/validar-escenarios.mjs)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(aws s3 sync:*)",
      "Bash(aws lambda:*)",
      "Bash(aws cloudfront:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.deploy)"
    ]
  }
}

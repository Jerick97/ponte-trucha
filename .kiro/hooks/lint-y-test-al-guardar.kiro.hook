{
  "enabled": true,
  "name": "Lint y Pruebas al Guardar",
  "description": "Corre ESLint sobre el codigo fuente y las pruebas de la logica pura cuando se edita un archivo TypeScript",
  "version": "1.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npm run lint && npm run test",
    "timeout": 120
  }
}

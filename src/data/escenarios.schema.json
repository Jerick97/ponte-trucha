{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Banco de escenarios de Ponte Trucha Kids",
  "type": "object",
  "required": ["version", "escenarios"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "escenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/escenario" }
    }
  },
  "definitions": {
    "escenario": {
      "type": "object",
      "required": [
        "id",
        "tipo",
        "canal",
        "dificultad",
        "remitente",
        "mensaje",
        "respuestaCorrecta",
        "senales",
        "leccion",
        "permiteConversacion"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "tipo": {
          "type": "string",
          "enum": [
            "monedas-gratis",
            "sorteo-falso",
            "robo-de-cuenta",
            "hack-con-virus",
            "link-tramposo",
            "suplantacion-de-amigo",
            "legitimo"
          ]
        },
        "canal": {
          "type": "string",
          "enum": ["chat-juego", "whatsapp", "correo", "discord", "sms"]
        },
        "dificultad": { "type": "integer", "minimum": 1, "maximum": 3 },
        "remitente": {
          "type": "object",
          "required": ["nombre", "avatar", "verificado"],
          "additionalProperties": false,
          "properties": {
            "nombre": { "type": "string", "minLength": 1, "maxLength": 40 },
            "avatar": { "type": "string", "minLength": 1 },
            "verificado": { "type": "boolean" }
          }
        },
        "mensaje": { "type": "string", "minLength": 10, "maxLength": 240 },
        "asunto": { "type": "string", "minLength": 3, "maxLength": 80 },
        "respuestaCorrecta": { "type": "string", "enum": ["trampa", "confianza"] },
        "senales": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": ["fragmento", "explicacion"],
            "additionalProperties": false,
            "properties": {
              "fragmento": { "type": "string", "minLength": 2 },
              "explicacion": { "type": "string", "minLength": 10, "maxLength": 160 }
            }
          }
        },
        "leccion": { "type": "string", "minLength": 10, "maxLength": 120 },
        "permiteConversacion": { "type": "boolean" },
        "perfilEstafador": {
          "type": "object",
          "required": ["disfraz", "tacticas", "objetivo"],
          "additionalProperties": false,
          "properties": {
            "disfraz": { "type": "string", "minLength": 3 },
            "tacticas": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "objetivo": { "type": "string", "minLength": 3 }
          }
        }
      }
    }
  }
}
